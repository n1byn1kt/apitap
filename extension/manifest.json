{
  "manifest_version": 3,
  "name": "ApiTap — API Capture",
  "version": "0.1.0",
  "description": "Capture API traffic and generate replayable skill files",
  "permissions": ["debugger", "activeTab", "storage", "downloads"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
